{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "./Dockerfile",
    "context": "."
  },
  "deploy": {
    "startCommand": "python davinci_https_server.py",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}
